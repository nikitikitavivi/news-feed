# Server
PORT=3001

# ──────────────────────────────────────────────
#  IMPORTANT: Never commit real keys to git!
#  Copy this file to .env and fill in your values.
#  .env is in .gitignore — it will NOT be committed.
# ──────────────────────────────────────────────

# GNews API key — get one at https://gnews.io/register
GNEWS_KEY=your-gnews-api-key

# OpenAI API key — get one at https://platform.openai.com/api-keys  
OPENAI_KEY=sk-your-openai-key

# CORS: the URL where your SPA runs
# Local dev (Vite):               http://localhost:5173
# Docker (docker-compose up):     http://localhost:5173
# Production (Vercel):            https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Database connection string
# Local dev (npm run dev):        postgres://newsfeed:newsfeed@localhost:5432/newsfeed
# Docker (docker-compose up):     postgres://newsfeed:newsfeed@postgres:5432/newsfeed
# Production (Neon/Supabase):     postgres://user:pass@ep-xxxx.us-east-1.aws.neon.tech/db
DATABASE_URL=postgres://newsfeed:newsfeed@localhost:5432/newsfeed
