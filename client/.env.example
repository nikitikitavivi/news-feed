# Production: the URL where your API server is deployed
# When set, the client sends API requests to this origin instead of same-origin.
# Dev (Vite proxy): leave unset — the Vite dev server proxies /api for you.
# Vercel/static hosting: set to your API server URL, e.g.:
#   VITE_API_BASE=https://news-feed-api.vercel.app
VITE_API_BASE=
